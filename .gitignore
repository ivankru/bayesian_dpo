# Не игнорировать каталоги (чтобы были видны .py в подпапках)
!*/

# Игнорировать всё остальное
*

# Исключение: отслеживать .py файлы
!*.py

# Исключение: папка utils (содержит .py)
!utils/
!utils/*.py
!utils/datasets/
!utils/datasets/*.py
!utils/seed.py

# Исключение: скрипты (plot_val_distributions и др.)
!scripts/
!scripts/*.py

# Исключение: сам .gitignore должен быть в репозитории
!.gitignore

# Cursor: project skills (агентские инструкции для репозитория)
!.cursor/
!.cursor/skills/
!.cursor/skills/*/
!.cursor/skills/*/SKILL.md

# Папка чекпоинтов Jupyter
.ipynb_checkpoints/

# Папки с результатами и данными
alpaca2/
checkpoints/
