# Не игнорировать каталоги (чтобы были видны .py в подпапках)
!*/

# Игнорировать всё остальное
*

# Исключение: отслеживать .py файлы
!*.py

# Локальный CLI capability retention не в репозитории (логика в utils/metrics/capability_retention_eval.py)
/eval_capability_retention.py

# Исключение: папка config (base_config и прочие .py)
!config/
!config/*.py

# Исключение: папка utils (содержит .py)
!utils/
!utils/*.py
!utils/metrics/
!utils/metrics/*.py
!utils/datasets/
!utils/datasets/*.py
!utils/losses/
!utils/losses/*.py
!utils/seed.py

# Исключение: сам .gitignore должен быть в репозитории
!.gitignore

# Папка чекпоинтов Jupyter
.ipynb_checkpoints/

# Папки с результатами и данными
alpaca2/
ifeval2/
checkpoints/

# Локальные сценарии и тесты не коммитим (в конце файла: перекрывает !*.py для этих деревьев)
/scripts/
/scripts/**
/tests/
/tests/**
/test/
/test/**
